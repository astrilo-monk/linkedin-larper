GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Upstash Redis for persistent shareable URLs and rate-limiting
# If these are not provided, the app will fall back to in-memory storage (which breaks shareable links on Vercel)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
